# =============================================================================
# Auth & billing
# =============================================================================
# Required. Used for /admin/* endpoints AND as the legacy admin-bypass on
# /v1/* (so existing smoke tests keep working). Rotate periodically.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
DEMO_API_TOKEN=change-me-demo-token

# Where the billing SQLite DB lives. Defaults to <storage>/billing.db
# (which the docker-compose bind-mount already persists across restarts).
# BILLING_DB_PATH=/app/storage/billing.db

# Concurrency cap per user — max in-flight billable requests at any moment.
BILLING_INFLIGHT_LIMIT=2

# Rate limit per API key — requests per 60-second sliding window.
BILLING_RATE_LIMIT_PER_MIN=10

# Free credits to give every fresh /v1/register account. Default 0 = no
# trial. Set e.g. 100 to give one cezi call on the house.
REGISTER_INITIAL_CREDITS=0

# ===== Stripe =====
# Modes: test|live. Code reads the matching key suffix below.
STRIPE_MODE=test

# From dashboard.stripe.com → Developers → API keys (TEST + LIVE).
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_PUBLISHABLE_KEY_LIVE=

# For local dev: run `stripe listen --forward-to http://localhost:8000/webhooks/stripe`
# and copy the printed `whsec_...` here.
# For prod: dashboard.stripe.com → Developers → Webhooks → add endpoint
# `https://<your-domain>/webhooks/stripe` listening to checkout.session.completed.
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=

# Where to redirect users after Stripe Checkout. {CHECKOUT_SESSION_ID} is
# substituted by Stripe; the billing.html page polls /v1/balance until
# the webhook lands. Replace https://your.host with the public URL.
STRIPE_SUCCESS_URL=https://your.host/billing.html?status=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://your.host/billing.html?status=cancelled

# Comma-separated payment methods exposed at Checkout. Default: "card,wechat_pay".
# IMPORTANT: each method here must also be enabled per-account at
# https://dashboard.stripe.com/test/settings/payment_methods (and the live
# equivalent). Listing wechat_pay when your Stripe account has not turned
# it on will make Session.create return 400 invalid_request_error. If
# WeChat Pay isn't available for your account country, set this to "card".
STRIPE_PAYMENT_METHODS=card,wechat_pay

# =============================================================================
# LLM config
# =============================================================================
# Set LLM_MODE=stub for offline smoke tests (no provider calls).
LLM_MODE=stub
LLM_ROUTE_CONFIG=config/llm_routes.json
LLM_ROUTING_ENABLED=1
GPTPROTO_API_BASE=https://gptproto.com/v1
GPTPROTO_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
LLM_MODEL=gemini-3.1-pro-preview
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_PARALLEL_WORKERS=
LLM_DEBUG=0
LLM_TRACE_RAW=0

# Cache behavior.
LLM_BYPASS_CACHE=0

# =============================================================================
# First-time deploy cheatsheet
# =============================================================================
# 1. Edit DEMO_API_TOKEN above to a strong random string.
# 2. docker compose up -d --build
# 3. Open the first user account (returns the one-time API key — store it):
#      curl -X POST http://YOUR_HOST/admin/users \
#        -H "Authorization: Bearer $DEMO_API_TOKEN" \
#        -H "Content-Type: application/json" \
#        -d '{"user_id":"u_alice","display_name":"Alice","initial_credits":1000}'
# 4. Customer integrations use the returned api_key:
#      curl -X POST http://YOUR_HOST/v1/cezi/ask \
#        -H "Authorization: Bearer <api_key>" \
#        -H "Content-Type: application/json" \
#        -d '{"question":"项目能不能成?","character":"合"}'
# 5. The user can self-service via http://YOUR_HOST/billing.html
#    (paste their api_key into the page; balance + usage + key management).
# 6. Top up later:
#      curl -X POST http://YOUR_HOST/admin/topup \
#        -H "Authorization: Bearer $DEMO_API_TOKEN" \
#        -H "Content-Type: application/json" \
#        -d '{"user_id":"u_alice","amount_credits":500,"note":"refill"}'
# 7. Pricing lives in `config/pricing.json` — edit and restart to change.
# 8. End users can self-register at http://YOUR_HOST/register.html and
#    self-topup via Stripe at /billing.html (after you fill the
#    STRIPE_*_TEST values above and add a public webhook in the Stripe
#    dashboard pointing at https://YOUR_HOST/webhooks/stripe).
