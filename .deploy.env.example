# Copy to .deploy.env and fill values locally. Do not commit .deploy.env.
#
# This file is read by scripts/deploy_volcengine.sh on your local machine.
# The script then writes /opt/mirror_ai_agent/.env on the server.

# -----------------------------------------------------------------------------
# Server / Git
# -----------------------------------------------------------------------------
DEPLOY_HOST=1.2.3.4
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_DOMAIN=api.mymirrorai.com
DEPLOY_REPO=https://github.com/edwardzhengsiyuan/mirror_ai_agent.git
DEPLOY_BRANCH=master
DEPLOY_PATH=/opt/mirror_ai_agent
DEPLOY_STRICT_PREFLIGHT=0
# Keep 0 for first deploy. Set 1 only after you have appended the generated
# Caddy snippet to /etc/caddy/Caddyfile and reloaded host-level Caddy.
DEPLOY_VERIFY_PUBLIC=0

# Optional. Leave blank to use your default SSH agent/config.
# On Windows Git Bash/WSL, use paths like /c/Users/you/.ssh/id_ed25519.
SSH_KEY_PATH=

# -----------------------------------------------------------------------------
# Image-only deployment (private registry)
# -----------------------------------------------------------------------------
# Used by scripts/deploy_volcengine_image.sh. The old deploy_volcengine.sh still
# builds from source on the server; the image-only script only pulls IMAGE_REF.
#
# Recommended for Volcengine: create a private image repository in Volcengine
# Container Registry, then use its full image reference here.
# Example:
#   IMAGE_REF=registry-cn-beijing.volces.com/your-namespace/mirror-ai-agent:latest
IMAGE_REF=

# Registry login is optional if the server is already logged in. Fill these to
# let the deploy script run `docker login` for you. Do NOT commit real values.
REGISTRY_HOST=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# After the first successful image-only deploy, set this to 1 to remove the
# old source checkout from DEPLOY_PATH on the server. Preserves .env, storage/,
# deploy/, and docker-compose.image-only.yml.
DEPLOY_IMAGE_PRUNE_SOURCE=0

# -----------------------------------------------------------------------------
# Auth / billing
# -----------------------------------------------------------------------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DEMO_API_TOKEN=

# Signs developer-portal session cookies (login on /dashboard). MUST be
# stable across deploys — rotating it forces every logged-in user to log
# back in. Generate the same way:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=

# Set to 0 only for HTTP local dev. In production keep this 1 so cookies
# carry the Secure flag.
APP_COOKIE_SECURE=1

BILLING_ADMIN_BYPASS=0
BILLING_INFLIGHT_LIMIT=2
BILLING_RATE_LIMIT_PER_MIN=10
REGISTER_INITIAL_CREDITS=0

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Empty LLM_MODE means production mode. Do not set "stub" for live deployments.
LLM_MODE=
GPTPROTO_API_BASE=https://gptproto.com/v1
GPTPROTO_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
LLM_MODEL=gemini-3.1-pro-preview
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_PARALLEL_WORKERS=
LLM_DEBUG=0
LLM_TRACE_RAW=0
LLM_BYPASS_CACHE=0

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Start with test if live activation is not ready yet. Switch to live only after
# Stripe account activation and dashboard webhook creation.
STRIPE_MODE=test

STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

STRIPE_SECRET_KEY_LIVE=
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Safe default: card. Use card,wechat_pay only after Stripe approves WeChat Pay.
STRIPE_PAYMENT_METHODS=card

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
