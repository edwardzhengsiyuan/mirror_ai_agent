# Copy to .deploy.env and fill values locally. Do not commit .deploy.env.
#
# This file is read by scripts/deploy_volcengine.sh on your local machine.
# The script then writes /opt/mirror_ai_agent/.env on the server.

# -----------------------------------------------------------------------------
# Server / Git
# -----------------------------------------------------------------------------
DEPLOY_HOST=1.2.3.4
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_DOMAIN=api.mymirrorai.com
DEPLOY_REPO=https://github.com/edwardzhengsiyuan/mirror_ai_agent.git
DEPLOY_BRANCH=master
DEPLOY_PATH=/opt/mirror_ai_agent
DEPLOY_STRICT_PREFLIGHT=0
# Keep 0 for first deploy. Set 1 only after you have appended the generated
# Caddy snippet to /etc/caddy/Caddyfile and reloaded host-level Caddy.
DEPLOY_VERIFY_PUBLIC=0

# Optional. Leave blank to use your default SSH agent/config.
# On Windows Git Bash/WSL, use paths like /c/Users/you/.ssh/id_ed25519.
SSH_KEY_PATH=

# -----------------------------------------------------------------------------
# Auth / billing
# -----------------------------------------------------------------------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DEMO_API_TOKEN=
BILLING_ADMIN_BYPASS=0
BILLING_INFLIGHT_LIMIT=2
BILLING_RATE_LIMIT_PER_MIN=10
REGISTER_INITIAL_CREDITS=0

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Empty LLM_MODE means production mode. Do not set "stub" for live deployments.
LLM_MODE=
GPTPROTO_API_BASE=https://gptproto.com/v1
GPTPROTO_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
LLM_MODEL=gemini-3.1-pro-preview
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_PARALLEL_WORKERS=
LLM_DEBUG=0
LLM_TRACE_RAW=0
LLM_BYPASS_CACHE=0

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Start with test if live activation is not ready yet. Switch to live only after
# Stripe account activation and dashboard webhook creation.
STRIPE_MODE=test

STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

STRIPE_SECRET_KEY_LIVE=
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Safe default: card. Use card,wechat_pay only after Stripe approves WeChat Pay.
STRIPE_PAYMENT_METHODS=card

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
